<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github-timewarp" value="https://nuget.pkg.github.com/TimeWarpEngineering/index.json" />
  </packageSources>
  <packageSourceMapping>
    <!-- Default: all packages from nuget.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <!-- TimeWarp packages from GitHub Packages -->
    <packageSource key="github-timewarp">
      <package pattern="TimeWarp.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
